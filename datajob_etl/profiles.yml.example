# dbt profiles.yml example
# Este es un archivo de ejemplo. Para generar tu profiles.yml con configuración
# óptima según tu sistema, ejecuta:
#   python utils/generate_dbt_profile.py
#
# El script calculará automáticamente:
# - Número óptimo de threads según tus CPU cores
# - Configuración de conexión desde variables de entorno

datajob_etl:
  target: dev
  outputs:
    dev:
      type: postgres
      host: localhost          # O usa {{ env_var('DB_HOST') }}
      port: 5432              # O usa {{ env_var('DB_PORT') }}
      user: postgres          # O usa {{ env_var('DB_USER') }}
      password: postgres      # O usa {{ env_var('DB_PASSWORD') }}
      dbname: job_posting     # O usa {{ env_var('DB_NAME') }}
      schema: public
      threads: 4              # Será calculado automáticamente según tu CPU
      keepalives_idle: 0
      connect_timeout: 10
      
    prod:
      type: postgres
      host: "{{ env_var('DB_HOST') }}"
      port: "{{ env_var('DB_PORT') }}"
      user: "{{ env_var('DB_USER') }}"
      password: "{{ env_var('DB_PASSWORD') }}"
      dbname: "{{ env_var('DB_NAME') }}"
      schema: public
      threads: 8              # Más threads para producción
      keepalives_idle: 0
      connect_timeout: 10
